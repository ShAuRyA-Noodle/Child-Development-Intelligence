# Database
DATABASE_URL="postgresql://ecd_user:ecd_password@localhost:5432/ecd_intelligence?schema=public"

# Redis (for BullMQ job queues)
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-this-to-a-secure-random-string-at-least-64-chars"
JWT_EXPIRY="15m"
REFRESH_TOKEN_EXPIRY="7d"

# Server
PORT=3001
NODE_ENV="development"

# Risk Engine (FastAPI ML service — Phase 2)
RISK_ENGINE_URL="http://localhost:8000/api/v1/predict"
